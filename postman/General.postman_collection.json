        {
          "name": "Check all information about current user",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"The current user has returned all information and shour return status code 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "    });",
                  "",
                  "pm.test(\"The current user has returned all information\", function () {",
                  "    const responseData = pm.response.json();",
                  "",
                  "    pm.expect(responseData.username).to.eql(pm.collectionVariables.get(\"current_username\"));",
                  "    pm.expect(responseData.firstName).to.eql(pm.collectionVariables.get(\"current_firstname\"));",
                  "    pm.expect(responseData.lastName).to.eql(pm.collectionVariables.get(\"current_lastname\"));",
                  "    pm.expect(responseData.email).to.eql(pm.collectionVariables.get(\"current_email\"));",
                  "    pm.expect(responseData.phone).to.eql(pm.collectionVariables.get(\"current_phone\"));",
                  "    pm.expect(responseData.userStatus).to.eql(pm.collectionVariables.get    (\"current_userStatus\"));",
                  "",
                  "    ",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
