              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const requestBody = JSON.parse(pm.request.body.raw);",
                  "",
                  "pm.collectionVariables.set(\"current_username\", requestBody.username);",
                  "pm.collectionVariables.set(\"current_password\", requestBody.password);",
                  "pm.collectionVariables.set(\"current_email\", requestBody.email);",
                  "pm.collectionVariables.set(\"current_phone\", requestBody.phone);",
                  "pm.collectionVariables.set(\"current_firstname\", requestBody.firstName);",
                  "pm.collectionVariables.set(\"current_lastname\", requestBody.lastName);",
                  "pm.collectionVariables.set(\"current_userStatus\",requestBody.userStatus)",
                  "",
                  "",
                  "",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n   \"username\": \"{{$randomUserName}}\",\n  \"firstName\": \"{{$randomFullName}}\",\n  \"lastName\": \"{{$randomLastName}}\",\n  \"email\": \"{{$randomEmail}}\",\n  \"password\": \"{{$randomPassword}}\",\n  \"phone\": \"{{$randomPhoneNumber}}\",\n  \"userStatus\": {{$randomInt}}\n}",
              "options": {
                "raw": {
                  "language": "json"
